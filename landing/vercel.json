{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/clip-review", "destination": "/clip-review.html" }
  ],
  "redirects": [
    { "source": "/clip-review.html", "destination": "/clip-review", "permanent": true }
  ],
  "headers": [
    {
      "source": "/downloads/(.*)",
      "headers": [
        { "key": "Content-Disposition", "value": "attachment" },
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    }
  ]
}
